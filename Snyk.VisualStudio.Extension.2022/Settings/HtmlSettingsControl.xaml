<UserControl x:Class="Snyk.VisualStudio.Extension.Settings.HtmlSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             UseLayoutRounding="True">
    <!-- White host background so nothing dark shows behind the WebView2 before its first
         paint; the settings page itself is always rendered in light mode. -->
    <Grid Background="White">
        <!-- Hidden (not Collapsed, so it keeps its size and renders offscreen) until the first
             navigation completes. The white Grid + loading label show meanwhile, so the dark
             WebView2 surface never flashes on screen before the HTML paints. -->
        <wv2:WebView2 x:Name="SettingsBrowser"
                      Visibility="Hidden"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch" />
        <TextBlock x:Name="LoadingStatusLabel"
                   Text="Loading settings..."
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
