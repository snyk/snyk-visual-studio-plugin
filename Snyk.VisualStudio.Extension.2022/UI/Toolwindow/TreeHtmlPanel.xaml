<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             x:Class="Snyk.VisualStudio.Extension.UI.Toolwindow.TreeHtmlPanel"
             toolkit:Themes.UseVsTheme="True"
             UseLayoutRounding="True"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300">
    <Grid x:Name="RootGrid">
        <!-- Themed WPF placeholder shown until the first tree HTML arrives. The WebView2 is
             collapsed until then so its dark pre-initialization surface is never visible
             (DefaultBackgroundColor only applies once the browser controller exists). -->
        <TextBlock x:Name="LoadingText"
                   Text="Loading…"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <wv2:WebView2 x:Name="TreeHtmlViewer"
                      Visibility="Collapsed"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch" />
    </Grid>
</UserControl>
