<UserControl x:Class="Snyk.VisualStudio.Extension.UI.Toolwindow.SnykToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:window="clr-namespace:Snyk.VisualStudio.Extension.UI.Toolwindow"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="SnykToolWindow" Loaded="SnykToolWindow_Loaded">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1" Grid.Column="0" Name="mainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="170" MinHeight="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="60"/>
                </Grid.RowDefinitions>
                <window:SummaryHtmlPanel Grid.Row="0" x:Name="SummaryPanel"/>

                <!-- Idiomatic VS divider: a 1px themed separator line drawn over a wider (6px),
                     transparent GridSplitter grab area. The splitter supplies the SizeNS resize
                     cursor on hover, which is VS's primary "draggable" affordance.
                     ShowsPreview is OFF deliberately: the preview is a WPF adorner, and the
                     WebView2 panels are HWND-hosted (airspace) so they always render above WPF
                     content — the preview bar would be hidden behind them. Live resize avoids
                     this entirely. -->
                <GridSplitter Grid.Row="1"
                              Height="6"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              ShowsPreview="False"/>
                <Border Grid.Row="1"
                        x:Name="horizontalDivider"
                        Height="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        IsHitTestVisible="False"/>

                <window:TreeHtmlPanel Grid.Row="2" x:Name="TreeHtmlPanel"/>
            </Grid>

            <!-- Vertical divider between the summary/tree column and the issue-details column.
                 Same pattern as the horizontal one: transparent 6px grab area + 1px themed line,
                 live resize (no occluded preview adorner over the WebView2 panels). -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="False"/>
            <Border Grid.Column="1"
                    x:Name="verticalDivider"
                    Width="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"/>

            <StackPanel Grid.Column="3" Name="progressBarPanel" Visibility="Collapsed" Orientation="Vertical" Margin="1" UseLayoutRounding="False">
                <Grid>
                    <ProgressBar x:Name="progressBar" Minimum="0" Maximum="100" Height="3"/>
                </Grid>
            </StackPanel>

            <window:HtmlDescriptionPanel Grid.Column="4" 
                                     x:Name="DescriptionPanel" 
                                     Visibility="Collapsed" 
                                     HorizontalContentAlignment="Stretch" 
                                     VerticalContentAlignment="Stretch"/>
            <window:MessagePanel Grid.Column="5" 
                                 x:Name="messagePanel" 
                                 HorizontalContentAlignment="Stretch" 
                                 VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
